generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
  }

  model Company {
    id                 String   @id @default(uuid())
    cnpj               String   @unique
    razaoSocial        String   
    nomeFantasia       String?
    email              String?
    telefonePrincipal  String?
    telefoneSecundario String?

    cep                String?
    logradouro         String?
    numero             String?
    complemento        String?
    bairro             String?
    cidade             String?
    uf                 String?

    observacoes        String?  @db.Text
    ativo              Boolean  @default(true)

    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt

    quotes             Quote[]
    prospects          Prospect[]
  }

  enum StatusAtendimento {
    PENDENTE
    EM_ATENDIMENTO
    APROVADO
    PROPOSTA_ENVIADA
    REPROVADO
    POSSIBILIDADE
    RETORNAR
    CNPJ_BAIXADO
  }

  model Prospect {
    id                 String            @id @default(uuid())
    
    cnpj               String            @unique
    nome               String
    telefone           String?
    simplesNacional    String?
    situacaoCadastral  String?
    telefoneSecundario String?
    email              String?
    atividadePrincipal String?
    telefoneBackup     String?
    nomeFantasia       String?
    endereco           String?
    bairro             String?
    cidade             String?
    estado             String?
    cep                String?
    
    modulosAtuais      String?
    valor              Float?

    observacoes        String?           @db.Text
    novosModulos       String[]          
    status             StatusAtendimento @default(PENDENTE)
    
    clienteWLE         Boolean           @default(false)
    
    lockedBy           String?           
    lockedAt           DateTime?
    atendidoPor        String?           
    dataAtendimento    DateTime?         
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt

    historicos         HistoricoAtendimento[]
    orders             Order[]

    companyId          String?
    company            Company?          @relation(fields: [companyId], references: [id])
  }

  model User {
    id                 String   @id @default(uuid())
    nome               String
    usuario            String   @unique
    senha              String   
    primeiroAcesso     Boolean  @default(true)
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt 

    roleId             String?
    role               Role?    @relation(fields: [roleId], references: [id])

    theme              Theme    @default(OCEAN)
    shape              Shape    @default(MODERN)
  }

  model HistoricoAtendimento {
    id                 String   @id @default(uuid())
    prospectId         String
    prospect           Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
    
    acao               String   
    observacoes        String?  @db.Text
    novosModulos       String[]
    usuario            String   
    
    createdAt          DateTime @default(now())
  }

model Quote {
  id                 Int      @id @default(autoincrement())
  
  nomeCliente        String
  cnpj               String
  email              String?
  telefonePrincipal  String?
  telefoneSecundario String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  uf                 String?
  
  modulos            String[]
  plano              String
  
  valorBase          Float
  valorNegociado     Float
  
  usuariosExtras     Int      @default(0)
  valorUsuarioExtra  Float    @default(0)

  interesses         String?  @db.Text
  observacoes        String?  @db.Text
  
  status             String   @default("RASCUNHO")
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  notas              QuoteNote[] 
  historico          QuoteHistory[]

  order              Order?

  companyId          String?
  company            Company? @relation(fields: [companyId], references: [id])
}

model QuoteNote {
  id        String   @id @default(uuid())
  quoteId   Int
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  texto     String   @db.Text
  usuario   String   
  
  createdAt DateTime @default(now())
}

model QuoteHistory {
  id        String   @id @default(uuid())
  quoteId   Int
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  acao      String   
  usuario   String  
  createdAt DateTime @default(now())
}

model Order {
  id               String      @id @default(uuid())
  orderNumber      Int         @unique @default(autoincrement()) 
  
  quoteId          Int         @unique
  quote            Quote       @relation(fields: [quoteId], references: [id])
  prospectId       String?     
  prospect         Prospect?   @relation(fields: [prospectId], references: [id])

  valorTotal       Float
  modulos          String[]
  
  status           OrderStatus @default(PENDENTE_ASSINATURA)
  tokenAssinatura  String?     @unique
  assinaturaUrl    String?     @db.Text
  termoAceitoAt    DateTime?
  ipAssinatura     String?
  userAgent        String?    

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum OrderStatus {
  PENDENTE_ASSINATURA
  ASSINADO
  CANCELADO
  CONCLUIDO
}

enum CategoriaRelease {
  NOVIDADE
  MELHORIA
  FIX
}

model ReleaseNote {
  id          Int              @id @default(autoincrement())
  versao      String
  titulo      String
  descricao   String           @db.Text
  categoria   CategoriaRelease
  createdAt   DateTime         @default(now())
}

model Role {
  id          String           @id @default(uuid())
  nome        String           @unique
  descricao   String?
  
  users       User[]
  permissions RolePermission[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  slug        String           @unique
  descricao   String         
  modulo      String          
  
  roles       RolePermission[]

  createdAt   DateTime         @default(now())
}

model RolePermission {
  roleId       String
  permissionId String
  
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

enum Theme {
  OCEAN
  MIDNIGHT
  COFFEE
}

enum Shape {
  SHARP
  MODERN
  SOFT
}

model Plan {
  id                 String   @id @default(uuid())
  nome               String
  modulosInclusos    String[]
  quantidadeUsuarios Int
  descricao          String?  @db.Text
  valorBase          Float
  percentualPorCnpj  Float

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}