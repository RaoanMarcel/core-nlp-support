  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
  }

  enum StatusAtendimento {
    PENDENTE
    EM_ATENDIMENTO
    APROVADO
    PROPOSTA_ENVIADA
    REPROVADO
    POSSIBILIDADE
    RETORNAR
  }

  model Prospect {
    id                 String            @id @default(uuid())
    cnpj               String            @unique
    nome               String
    modulosAtuais      String?
    telefone           String?
    
    simplesNacional    String?
    situacaoCadastral  String?
    telefoneSecundario String?
    email              String?
    atividadePrincipal String?
    telefoneBackup     String?
    nomeFantasia String?
    endereco     String?
    bairro       String?
    cidade       String?
    estado       String?
    cep          String?

    valor              Float?

    observacoes        String?           @db.Text
    novosModulos       String[]          
    status             StatusAtendimento @default(PENDENTE)
    
    clienteWLE         Boolean           @default(false)
    
    lockedBy           String?           
    lockedAt           DateTime?
    atendidoPor        String?           
    dataAtendimento    DateTime?         
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt

    historicos         HistoricoAtendimento[]
    orders             Order[]
  }

  model User {
    id              String   @id @default(uuid())
    nome            String
    usuario         String   @unique
    senha           String   
    primeiroAcesso  Boolean  @default(true)
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt 
  }

  model HistoricoAtendimento {
    id            String   @id @default(uuid())
    prospectId    String
    prospect      Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
    
    acao          String   // Ex: "Em Atendimento", "Atualizado", "Aprovado"
    observacoes   String?  @db.Text
    novosModulos  String[]
    usuario       String   // Nome do usuário que fez a alteração
    
    createdAt     DateTime @default(now())
  }

model Quote {
  id                 Int      @id @default(autoincrement())
  nomeCliente        String
  cnpj               String
  endereco           String?
  email              String?
  telefonePrincipal  String?
  telefoneSecundario String?
  modulos            String[]
  plano              String
  
  valorBase          Float
  valorNegociado     Float
  
  interesses         String?  @db.Text
  observacoes        String?  @db.Text
  
  status             String   @default("RASCUNHO")
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  notas     QuoteNote[] 
  historico QuoteHistory[]

  order    Order?
}

model QuoteNote {
  id        String   @id @default(uuid())
  quoteId   Int
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  texto     String   @db.Text
  usuario   String   
  
  createdAt DateTime @default(now())
}

model QuoteHistory {
  id        String   @id @default(uuid())
  quoteId   Int
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  acao      String   
  usuario   String  
  createdAt DateTime @default(now())
}

model Order {
  id               String   @id @default(uuid())
  orderNumber      Int      @unique @default(autoincrement()) 
  
  quoteId          Int      @unique
  quote            Quote    @relation(fields: [quoteId], references: [id])
  prospectId       String?     
  prospect         Prospect? @relation(fields: [prospectId], references: [id])

  valorTotal       Float
  modulos          String[]
  
  status           OrderStatus @default(PENDENTE_ASSINATURA)
  tokenAssinatura  String?     @unique
  assinaturaUrl    String?     @db.Text
  termoAceitoAt    DateTime?
  ipAssinatura     String?
  userAgent        String?    

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

enum OrderStatus {
  PENDENTE_ASSINATURA
  ASSINADO
  CANCELADO
  CONCLUIDO
}

enum CategoriaRelease {
  NOVIDADE
  MELHORIA
  FIX
}

model ReleaseNote {
  id          Int              @id @default(autoincrement())
  versao      String
  titulo      String
  descricao   String           @db.Text
  categoria   CategoriaRelease
  createdAt   DateTime         @default(now())
}