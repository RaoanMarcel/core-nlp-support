generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusAtendimento {
  PENDENTE
  EM_ATENDIMENTO
  APROVADO
  REPROVADO
}

model Prospect {
  id                 String            @id @default(uuid())
  cnpj               String            @unique
  nome               String
  modulosAtuais      String?
  telefone           String?
  
  // === NOVAS COLUNAS ===
  simplesNacional    String?
  situacaoCadastral  String?
  telefoneSecundario String?
  email              String?
  atividadePrincipal String?
  telefoneBackup     String?
  // =====================

  observacoes        String?           @db.Text
  novosModulos       String[]          
  status             StatusAtendimento @default(PENDENTE)
  
  lockedBy           String?           
  lockedAt           DateTime?
  
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model User {
  id        String   @id @default(uuid())
  nome      String
  usuario   String   @unique // Será o login (ex: joao.silva)
  senha     String   // Aqui vai o hash do bcrypt, nunca a senha real
  primeiroAcesso Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}