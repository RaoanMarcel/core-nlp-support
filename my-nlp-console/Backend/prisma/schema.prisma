generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusAtendimento {
  PENDENTE
  EM_ATENDIMENTO
  APROVADO
  REPROVADO
  POSSIBILIDADE
  RETORNAR
}

model Prospect {
  id                 String            @id @default(uuid())
  cnpj               String            @unique
  nome               String
  modulosAtuais      String?
  telefone           String?
  
  simplesNacional    String?
  situacaoCadastral  String?
  telefoneSecundario String?
  email              String?
  atividadePrincipal String?
  telefoneBackup     String?

  observacoes        String?           @db.Text
  novosModulos       String[]          
  status             StatusAtendimento @default(PENDENTE)
  
  clienteWLE         Boolean           @default(false)
  
  lockedBy           String?           
  lockedAt           DateTime?
  atendidoPor        String?           
  dataAtendimento    DateTime?         
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model User {
  id              String   @id @default(uuid())
  nome            String
  usuario         String   @unique
  senha           String   
  primeiroAcesso  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt 
}
