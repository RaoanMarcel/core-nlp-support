---
// src/pages/[...slug].astro
import AppRouter from '../components/AppRouter';
import '../styles/global.css'; 

// 1. Adicionamos esta função para avisar ao Astro quais URLs existem no seu React Router
export function getStaticPaths() {
  return [
    { params: { slug: 'fila' } },
    { params: { slug: 'relatorios' } },
    { params: { slug: 'base' } },
    { params: { slug: 'contratos' } },
  ];
}
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Core NLP | PRO4CE </title>
  </head>
  <body class="m-0 p-0 h-screen w-screen overflow-hidden text-slate-900 bg-[#f8f9f9]">
    <AppRouter client:only="react" />
  </body>
</html>